TZ=Europe/Paris

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.tld

# Dashboard Traefik
TRAEFIK_DASHBOARD_HOST=traefik.example.tld

# Hash BasicAuth — générer avec : htpasswd -nbB admin 'ton_mot_de_passe'
# ATTENTION : dans un fichier .env, chaque $ doit être doublé en $$
# Exemple : admin:$2y$... devient admin:$$2y$$...
TRAEFIK_DASHBOARD_BASIC_AUTH=admin:$$2y$$05$$REMPLACE_MOI_PAR_UN_VRAI_HASH
