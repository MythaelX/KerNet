TZ=Europe/Paris

# Domaine
VAULTWARDEN_HOST=vault.example.tld

# Sécurité
VAULTWARDEN_SIGNUPS_ALLOWED=false
# Génère un token fort: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM

# PostgreSQL (base dédiée Vaultwarden)
VW_DB_NAME=vaultwarden
VW_DB_USER=vaultwarden
VW_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
